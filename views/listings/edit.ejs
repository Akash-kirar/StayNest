<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-12 col-md-8 offset-md-2">
    <h3>Edit Your Listing</h3>
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >

      <div class="mb-3">
        <label for="title" class="form-label">Place Name</label>
        <input
          name="listing[title]"
          value="<%= listing.title %>"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks great!</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">About the Place</label>
        <textarea name="listing[description]" class="form-control" rows="4" required>
<%= listing.description %></textarea>
        <div class="invalid-feedback">Please add a short description</div>
      </div>

      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" class="form-select">
          <option value="Trending"    <%= listing.category === 'Trending'   ? 'selected' : '' %>>🔥 Trending</option>
          <option value="Beachfront"  <%= listing.category === 'Beachfront' ? 'selected' : '' %>>🌊 Beachfront</option>
          <option value="Islands"     <%= listing.category === 'Islands'    ? 'selected' : '' %>>🏖️ Islands</option>
          <option value="Mountains"   <%= listing.category === 'Mountains'  ? 'selected' : '' %>>🏔️ Mountains</option>
          <option value="Cabins"      <%= listing.category === 'Cabins'     ? 'selected' : '' %>>🌲 Cabins</option>
          <option value="Camping"     <%= listing.category === 'Camping'    ? 'selected' : '' %>>⛺ Camping</option>
          <option value="Boats"       <%= listing.category === 'Boats'      ? 'selected' : '' %>>⛵ Boats</option>
          <option value="Pools"       <%= listing.category === 'Pools'      ? 'selected' : '' %>>🏊 Pools</option>
          <option value="Castles"     <%= listing.category === 'Castles'    ? 'selected' : '' %>>🏰 Castles</option>
          <option value="Arctic"      <%= listing.category === 'Arctic'     ? 'selected' : '' %>>❄️ Arctic</option>
          <option value="Domes"       <%= listing.category === 'Domes'      ? 'selected' : '' %>>🏛️ Domes</option>
          <option value="Farms"       <%= listing.category === 'Farms'      ? 'selected' : '' %>>🌾 Farms</option>
          <option value="Earthhomes"  <%= listing.category === 'Earthhomes' ? 'selected' : '' %>>🏠 Earthhomes</option>
          <option value="Villas"      <%= listing.category === 'Villas'     ? 'selected' : '' %>>🥂 Villas</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Current Photo</label> <br />
        <img src="<%= originalImageUrl %>" class="edit-preview-img" alt="Current listing image" />
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Upload New Photo</label>
        <input name="listing[image]" type="file" class="form-control" />
      </div>

      <div class="row">
        <div class="mb-3 col-12 col-md-4">
          <label for="price" class="form-label">Price per Night (₹)</label>
          <input
            name="listing[price]"
            value="<%= listing.price %>"
            type="number"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a valid price</div>
        </div>

        <div class="mb-3 col-12 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            value="<%= listing.country %>"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a valid country</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location / Address</label>
        <input
          name="listing[location]"
          value="<%= listing.location %>"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter a valid location</div>
      </div>

      <button class="btn btn-dark editbtn mt-3 edit-btn">Save Changes</button>
    </form>
  </div>
</div>
