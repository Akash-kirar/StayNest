
<style>
  .search-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.45rem 1rem;
    white-space: nowrap;
  }

  .search-btn:hover {
    color: #000;
  }

  .search-input {
    border-radius: 25px;
    padding: 0.45rem 1.2rem;
    font-size: 1rem;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .navbar-search-form {
      min-width: 0;
      max-width: 200px;         /* cap width so hamburger fits on same row */
      flex-shrink: 1;
      margin-left: 0.4rem !important;
      margin-right: 0.3rem !important;
    }

    .search-input {
      flex: 1;
      min-width: 0;
      font-size: 0.82rem;
      padding: 0.38rem 0.6rem;
    }

    .search-btn {
      padding: 0.38rem 0.65rem;
      flex-shrink: 0;
    }
  }

  /* ---- Offcanvas mobile nav ---- */
  .offcanvas-nav-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.25rem;
    border-radius: 0.75rem;
    text-decoration: none;
    color: #222;
    font-weight: 500;
    font-size: 1.05rem;
    transition: background 0.18s ease, color 0.18s ease;
    margin-bottom: 0.35rem;
  }

  .offcanvas-nav-item:hover {
    background-color: #fff0f0;
    color: #fe424d;
  }

  .offcanvas-nav-item .ofc-icon {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: #fe424d;
    flex-shrink: 0;
    transition: background 0.18s ease;
  }

  .offcanvas-nav-item:hover .ofc-icon {
    background: #fe424d;
    color: #fff;
  }

  .offcanvas-divider {
    border: none;
    border-top: 1px solid #ebebeb;
    margin: 0.75rem 0;
  }

  .offcanvas-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: #222;
  }

  .offcanvas-brand .fa-compass {
    font-size: 1.6rem;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid flex-nowrap">

    <!-- Brand Logo -->
    <a class="navbar-brand flex-shrink-0" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- Search Bar (visible on ALL screen sizes) -->
    <form class="d-flex flex-grow-1 navbar-search-form mx-2" style="max-width:420px;"
      role="search" method="GET" action="/listings">
      <input class="form-control me-2 search-input" type="search" name="q"
        placeholder="Search..." aria-label="Search">
      <button class="btn search-btn flex-shrink-0" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </form>

    <!-- DESKTOP: Right links -->
    <ul class="navbar-nav d-none d-md-flex flex-row align-items-center gap-1 flex-shrink-0">
      <li class="nav-item"><a class="nav-link" href="/listings">Explore</a></li>
      <li class="nav-item"><a class="nav-link" href="/listings/new">Add New Listing</a></li>
      <% if(!currUser) { %>
      <li class="nav-item"><a class="nav-link" href="/signup"><b>Sign up</b></a></li>
      <li class="nav-item"><a class="nav-link" href="/login"><b>Log in</b></a></li>
      <% } %>
      <% if(currUser) { %>
      <li class="nav-item"><a class="nav-link" href="/logout"><b>Log out</b></a></li>
      <% } %>
    </ul>

    <!-- MOBILE: Hamburger (ms-auto keeps it at far right on same row) -->
    <button class="navbar-toggler d-md-none border-0 ms-auto flex-shrink-0" type="button"
      data-bs-toggle="offcanvas" data-bs-target="#mobileNavOffcanvas"
      aria-controls="mobileNavOffcanvas" aria-label="Open menu">
      <span class="navbar-toggler-icon"></span>
    </button>

  </div>
</nav>

<!-- ====== MOBILE OFFCANVAS DRAWER ====== -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="mobileNavOffcanvas"
  aria-labelledby="mobileNavOffcanvasLabel" style="max-width:300px;">

  <!-- Offcanvas Header -->
  <div class="offcanvas-header border-bottom pb-3">
    <div class="offcanvas-brand">
      <i class="fa-regular fa-compass" style="color:#fe424d;"></i>
      <span>WanderLust</span>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>

  <!-- Offcanvas Body -->
  <div class="offcanvas-body pt-3">

    <hr class="offcanvas-divider">

    <!-- Nav Links — navigate directly via href, no data-bs-dismiss that kills the click -->
    <a href="/listings" class="offcanvas-nav-item">
      <span class="ofc-icon"><i class="fa-solid fa-compass"></i></span>
      Explore
    </a>

    <a href="/listings/new" class="offcanvas-nav-item">
      <span class="ofc-icon"><i class="fa-solid fa-house-chimney"></i></span>
      Add New Listing
    </a>

    <hr class="offcanvas-divider">

    <% if(!currUser) { %>
    <a href="/signup" class="offcanvas-nav-item">
      <span class="ofc-icon"><i class="fa-solid fa-user-plus"></i></span>
      Sign up
    </a>
    <a href="/login" class="offcanvas-nav-item">
      <span class="ofc-icon"><i class="fa-solid fa-right-to-bracket"></i></span>
      Log in
    </a>
    <% } %>

    <% if(currUser) { %>
    <a href="/logout" class="offcanvas-nav-item">
      <span class="ofc-icon"><i class="fa-solid fa-right-from-bracket"></i></span>
      Log out
    </a>
    <% } %>

  </div>
</div>